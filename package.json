{
  "name": "hgt-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "build": "cd apps/web && npx vite build",
    "build:vercel": "cd apps/web && npx vite build",
    "build:all": "npm run build -w packages/shared && npm run build -w apps/server && npm run build -w apps/web",
    "check": "npm run check -w apps/server && npm run check -w apps/web",
    "test": "npm run test -w apps/server",
    "db:up": "docker compose up -d mysql",
    "start": "npm run start -w apps/server"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4"
  }
}
