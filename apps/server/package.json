{
  "name": "@hgt/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/nickname.test.ts src/soupSimilarity.test.ts src/stickers.test.ts src/shellCurrency.test.ts src/badgeRewards.test.ts src/digitalAssets.test.ts src/bannerImages.test.ts",
    "migrate": "tsx src/migrate.ts",
    "migrate:prod": "node dist/migrate.js",
    "start": "npm run build && node dist/index.js",
    "start:prod": "node dist/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.18.1",
    "mysql2": "^3.12.0",
    "nanoid": "^5.1.2",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "ws": "^8.21.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.13.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3"
  }
}
